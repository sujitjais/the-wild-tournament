# Supabase (optional - when set, app uses database instead of in-memory store)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App user session signing - REQUIRED in production (min 32 chars, use a random string)
APP_SESSION_SECRET=your-random-secret-at-least-32-characters-long
